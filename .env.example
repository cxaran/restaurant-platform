PROJECT_NAME=Restaurant Platform
ENVIRONMENT=local
TRUSTED_BROWSER_ORIGINS=http://localhost:3000

SECRET_KEY=change-me-use-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
EMAIL_TOKEN_EXPIRE_MINUTES=30
TRYS_BEFORE_LOCK=5

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_DB=restaurant_platform

SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=dev@example.com
SMTP_PASSWORD=dev-password
SMTP_FROM_EMAIL=dev@example.com
SMTP_FROM_NAME=Restaurant Platform Dev
SMTP_TLS=false
SMTP_SSL=false
SMTP_USE_CREDENTIALS=false

# Usado por: python -m backend.app.core.bootstrap
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=admin1234
BOOTSTRAP_ADMIN_NAME=Admin
BOOTSTRAP_ADMIN_LAST_NAME=Platform
BOOTSTRAP_ADMIN_ROLE_NAME=Administrador
BOOTSTRAP_USER_ROLE_NAME=Usuario

# Usado por Bootstrap HTTP de producto (/api/v1/bootstrap/*). Obligatorio en production.
BOOTSTRAP_SETUP_TOKEN=change-me-use-a-long-random-bootstrap-token

# CLAVE MAESTRA ÚNICA de cifrado de secretos de configuración en reposo (Fernet,
# urlsafe base64 de 32 bytes). Obligatoria en producción. Generar:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=
# Clave legada de la cadena de descifrado (despliegues previos); normalmente vacía.
BACKUP_TOKEN_ENCRYPTION_KEY=

# Respaldos hacia Google Drive. BACKUPS_ENABLED es el kill-switch del tick (el
# interruptor real es backup_settings.enabled, editable en la UI).
BACKUPS_ENABLED=true
BACKUP_EXPLORER_ENABLED=false
BACKUP_TEMP_DIR=/tmp/restaurant-platform-backups
BACKUP_RUN_LEASE_MINUTES=120
BACKUP_MAX_ATTEMPTS=3
# Las credenciales OAuth de Google Drive NO van en el entorno: se capturan en la
# UI de respaldos (client secret cifrado) y el redirect se deriva del dominio
# verificado de la instalación.
